{
  "manifest_version": 3,
  "name": "AI Chat Notification",
  "version": "1.2.1",
  "description": "当 Z.AI 对话回复完成时发送浏览器通知，让你即使切换到其他标签页也能及时知道回复已就绪。",
  "permissions": [
    "notifications",
    "storage",
    "activeTab",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://z.ai/*",
        "https://*.z.ai/*",
        "https://chatglm.cn/*",
        "https://*.chatglm.cn/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
